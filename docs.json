{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "All One Thing",
  "colors": {
    "primary": "#F59E0B",
    "light": "#FBBF24",
    "dark": "#D97706"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "All One Thing",
        "groups": [
          {
            "group": "About",
            "pages": [
              "index",
              "projects"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/allonethingxyz",
          "icon": "github"
        },
        {
          "anchor": "Sunschool Docs",
          "href": "https://docs.sunschool.xyz",
          "icon": "sun"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Sunschool Docs",
        "href": "https://docs.sunschool.xyz"
      }
    ],
    "primary": {
      "type": "button",
      "label": "View Projects",
      "href": "https://github.com/allonethingxyz"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/allonethingxyz",
      "website": "https://allonething.xyz"
    }
  }
}
